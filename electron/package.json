{
  "name": "xeragent-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "npx electron ."
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ellisdon.xeragent",
    "productName": "XER Schedule Assistant",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": ".",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "main.js",
      "package.json",
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ]
  }
}
